  "keyFeatures": [
    "Live TV channel streaming via M3U/HLS playlists",
    "Splash screen and onboarding flow",
    "On-device login with auto-login support",
    "Channel grid with category browsing",
    "Ad system with three display formats (A, B, C)",
    "Deep link support for live media type",
    "Connectivity polling and offline detection",
    "Settings panel with server management and channel refresh",
    "Roku Channel Store certification compliance",
    "Makefile-based build, sideload and packaging workflow"
  ],
  "publicApiSurface": [
    "make zip — Package the app into out/GlobalTV.zip",
    "make install ROKU_IP=x.x.x.x ROKU_PASS=xxxx — Sideload to Roku device",
    "make pkg ROKU_IP=x.x.x.x ROKU_PASS=xxxx SIGN_PASSWORD=xxxx — Generate signed .pkg",
    "make screenshot ROKU_IP=x.x.x.x ROKU_PASS=xxxx — Capture device screenshot",
    "make check — Verify Roku certification checklist",
    "make clean — Remove build artifacts",
    "AppConstants() — Central configuration object",
    "GTV_InitGlobalState() — Initialize m.global state fields",
    "GTV_Log() / GTV_Warn() / GTV_Error() — Logging functions",
    "GTV_GetSafeArea(node) — Compute UI safe area",
    "GTV_GetLayoutContext(node) — Compute scaled layout context",
    "GTV_AuthClassifyFailure(httpCode, reasonText, bodyText, subscriberActive) — Classify auth errors",
    "launchDeepLink / inputDeepLink — Deep link entry points (mediaType=live)"
  ]
